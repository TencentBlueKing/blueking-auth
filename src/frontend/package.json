{
  "name": "blueking-auth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node replace-index-html.js index.dev.html && vite",
    "build": "node replace-index-html.js index.prod.html && run-p type-check \"build-only {@}\" --",
    "preview": "node replace-index-html.js index.dev.html && vite preview",
    "build-only": "node replace-index-html.js index.prod.html && vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*"
  },
  "dependencies": {
    "@blueking/login-modal": "^1.0.6",
    "@unocss/reset": "^66.3.3",
    "@vueuse/components": "^14",
    "@vueuse/core": "^14",
    "@vueuse/integrations": "^14",
    "axios": "^1.11.0",
    "bkui-vue": "2.0.2-beta.93",
    "dayjs": "^1.11.19",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.3",
    "vue": "^3.5.30",
    "vue-i18n": "^11.1.11",
    "vue-router": "^5"
  },
  "devDependencies": {
    "vite": "^7.3.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rolldown/pluginutils": "1.0.0-beta.29",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.5",
    "@unocss/preset-wind4": "^66.6.6",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-oxlint": "^1.8.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "less": "^4.4.0",
    "lint-staged": "^16.1.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.8.0",
    "postcss-html": "^1.8.0",
    "sass-embedded": "^1.89.2",
    "simple-git-hooks": "^2.13.0",
    "stylelint": "^16.22.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "typescript": "~5.9.3",
    "unocss": "^66.3.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-turbo-console": "^2.2.0",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^2.2.12"
  },
  "simple-git-hooks": {
    "pre-commit": "cd src/front && npx lint-staged",
    "commit-msg": "cd src/front && npx commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
